# ============================================================
extract_first_two_counts <- function(x) {
    x <- as.character(x)

    nums_list <- stringr::str_extract_all(x, "[0-9]+")
    ref <- rep(NA_real_, length(nums_list))
    alt <- rep(NA_real_, length(nums_list))

    for (i in seq_along(nums_list)) {
        vals <- nums_list[[i]]
        if (length(vals) >= 2) {
            ref[i] <- as.numeric(vals[1])
            alt[i] <- as.numeric(vals[2])
        }
    }

    data.frame(ref_ct = ref, alt_ct = alt)
}

parse_ad_to_af <- function(x, allele = c("REF","ALT")) {
    allele <- match.arg(allele)

    counts <- extract_first_two_counts(x)
    tot <- counts$ref_ct + counts$alt_ct

    af <- rep(NA_real_, length(tot))
    ok <- !is.na(counts$ref_ct) & !is.na(counts$alt_ct) & tot > 0

    if (allele == "REF") {
        af[ok] <- counts$ref_ct[ok] / tot[ok]
    } else {
        af[ok] <- counts$alt_ct[ok] / tot[ok]
    }

    af
}

