# ============================================================
# TRICUBE SMOOTHER
# ============================================================
tricubeStat <- function(POS, Stat, windowSize = 1e5) {
    ord <- order(POS)
    x <- POS[ord]
    y <- Stat[ord]

    fit <- try(
        locfit::locfit(y ~ locfit::lp(x, h = windowSize, deg = 0)),
        silent = TRUE
    )

    out <- rep(NA_real_, length(POS))

    if (!inherits(fit, "try-error")) {
        pred <- try(stats::predict(fit, newdata = x), silent = TRUE)
        if (!inherits(pred, "try-error")) {
            out[ord] <- as.numeric(pred)
        }
    }

    if (all(is.na(out))) out <- Stat
    out
}

