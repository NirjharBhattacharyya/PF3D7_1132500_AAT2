extract_first_two_counts <- function(x) {
    x <- as.character(x)
    nums_list <- stringr::str_extract_all(x, "[0-9]+")
    ref <- rep(NA_real_, length(nums_list))
    alt <- rep(NA_real_, length(nums_list))

    for (i in seq_along(nums_list)) {
        vals <- nums_list[[i]]
        if (length(vals) >= 2) {
            ref[i] <- as.numeric(vals[1])
            alt[i] <- as.numeric(vals[2])
        }
    }

    data.frame(ref_ct = ref, alt_ct = alt)
}

# ============================================================
# RAW G STATISTIC
# ============================================================
calc_G_stat <- function(low_ref, low_alt, high_ref, high_alt) {
    obs <- cbind(low_ref, low_alt, high_ref, high_alt)

    row_tot_1 <- low_ref + low_alt
    row_tot_2 <- high_ref + high_alt
    col_tot_1 <- low_ref + high_ref
    col_tot_2 <- low_alt + high_alt
    grand_tot <- row_tot_1 + row_tot_2

    exp_low_ref  <- row_tot_1 * col_tot_1 / grand_tot
    exp_low_alt  <- row_tot_1 * col_tot_2 / grand_tot
    exp_high_ref <- row_tot_2 * col_tot_1 / grand_tot
    exp_high_alt <- row_tot_2 * col_tot_2 / grand_tot

    term_fun <- function(o, e) {
        out <- rep(0, length(o))
        ok <- !is.na(o) & !is.na(e) & o > 0 & e > 0
        out[ok] <- o[ok] * log(o[ok] / e[ok])
        out
    }

    g <- 2 * (
        term_fun(low_ref, exp_low_ref) +
        term_fun(low_alt, exp_low_alt) +
        term_fun(high_ref, exp_high_ref) +
        term_fun(high_alt, exp_high_alt)
    )

    g[!is.finite(g)] <- NA_real_
    g
}

# ============================================================
# LOCAL SMOOTHING FOR G' AND DELTASNP
# ============================================================
smooth_stat_locfit <- function(pos, stat, window_size = 1e5) {
    ord <- order(pos)
    x <- pos[ord]
    y <- stat[ord]

    out <- rep(NA_real_, length(pos))

    good <- is.finite(x) & is.finite(y)
    if (sum(good) < 10) return(out)

    xg <- x[good]
    yg <- y[good]

    fit <- try(
        locfit::locfit(yg ~ locfit::lp(xg, h = window_size, deg = 0)),
        silent = TRUE
    )

    if (inherits(fit, "try-error")) return(out)

    pred <- try(stats::predict(fit, newdata = x), silent = TRUE)
    if (inherits(pred, "try-error")) return(out)

    out[ord] <- as.numeric(pred)
    out
}

