# ============================================================
# HELPER: CONCATENATED GENOME COORDINATES
#   this is the key thing your other BSA code does
# ============================================================
make_genome_positions <- function(df) {
    chr_lengths <- df %>%
        dplyr::group_by(CHROM) %>%
        dplyr::summarise(chr_len = max(POS, na.rm = TRUE), .groups = "drop") %>%
        dplyr::mutate(CHROM = factor(as.character(CHROM), levels = chr_levels)) %>%
        dplyr::arrange(CHROM) %>%
        dplyr::mutate(
            chr_start = cumsum(dplyr::lag(chr_len, default = 0)),
            chr_end   = chr_start + chr_len
        )
    
    df2 <- df %>%
        dplyr::left_join(chr_lengths, by = "CHROM") %>%
        dplyr::mutate(genome_pos = POS + chr_start)
    
    axis_df <- chr_lengths %>%
        dplyr::mutate(
            center = (chr_start + chr_end) / 2,
            label  = gsub("Pf3D7_", "Chr ", gsub("_v3", "", as.character(CHROM)))
        )
    
    bg_df <- chr_lengths %>%
        dplyr::mutate(fill = rep(c("gray90", "white"), length.out = n()))
    
    list(df = df2, chr_lengths = chr_lengths, axis_df = axis_df, bg_df = bg_df)
}

