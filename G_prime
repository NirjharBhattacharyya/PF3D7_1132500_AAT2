# ============================================================
# HELPER: FIT GAMMA GLM THRESHOLDS
#   - for normal: uses all Gprime > 0
#   - for residual: uses masked Gprime_plot > 0
# ============================================================
calc_glm_thresholds <- function(df_masked, value_col = "Gprime_plot") {
    
    df_bg <- df_masked %>%
        dplyr::filter(!is.na(.data[[value_col]]), is.finite(.data[[value_col]]), .data[[value_col]] > 0) %>%
        dplyr::transmute(y = .data[[value_col]])
    
    if (nrow(df_bg) < 50) {
        return(tibble::tibble(
            mu_hat = NA_real_,
            phi_hat = NA_real_,
            shape_hat = NA_real_,
            scale_hat = NA_real_,
            thr_p10 = NA_real_,
            thr_p05 = NA_real_,
            thr_p01 = NA_real_,
            n_bg = nrow(df_bg)
        ))
    }
    
    glm_fit <- try(stats::glm(y ~ 1, family = Gamma(link = "log"), data = df_bg), silent = TRUE)
    
    if (inherits(glm_fit, "try-error")) {
        return(tibble::tibble(
            mu_hat = NA_real_,
            phi_hat = NA_real_,
            shape_hat = NA_real_,
            scale_hat = NA_real_,
            thr_p10 = NA_real_,
            thr_p05 = NA_real_,
            thr_p01 = NA_real_,
            n_bg = nrow(df_bg)
        ))
    }
    
    mu_hat  <- as.numeric(exp(stats::coef(glm_fit)))
    phi_hat <- summary(glm_fit)$dispersion
    shape_hat <- 1 / phi_hat
    scale_hat <- mu_hat * phi_hat
    
    tibble::tibble(
        mu_hat = mu_hat,
        phi_hat = phi_hat,
        shape_hat = shape_hat,
        scale_hat = scale_hat,
        thr_p10 = stats::qgamma(0.90, shape = shape_hat, scale = scale_hat),
        thr_p05 = stats::qgamma(0.95, shape = shape_hat, scale = scale_hat),
        thr_p01 = stats::qgamma(0.99, shape = shape_hat, scale = scale_hat),
        n_bg = nrow(df_bg)
    )
}

# ============================================================
# HELPER: ONE PAIRWISE G' COMPARISON
# ============================================================
make_gprime_pair <- function(control_id, treated_id) {
    
    out <- gprime_df[, c("CHROM", "POS"), drop = FALSE]
    
    out$LowRef  <- gprime_df[[paste0(control_id, "_REF")]]
    out$LowAlt  <- gprime_df[[paste0(control_id, "_ALT")]]
    out$HighRef <- gprime_df[[paste0(treated_id, "_REF")]]
    out$HighAlt <- gprime_df[[paste0(treated_id, "_ALT")]]
    
    out$DP1 <- out$LowRef + out$LowAlt
    out$DP2 <- out$HighRef + out$HighAlt
    
    out <- out %>%
        dplyr::filter(
            !is.na(LowRef), !is.na(LowAlt), !is.na(HighRef), !is.na(HighAlt),
            !is.na(DP1), !is.na(DP2),
            DP1 >= MIN_DEPTH, DP2 >= MIN_DEPTH
        )
    
    if (nrow(out) < 100) return(NULL)
    
    out$G <- calc_G_stat(
        low_ref  = out$LowRef,
        low_alt  = out$LowAlt,
        high_ref = out$HighRef,
        high_alt = out$HighAlt
    )
    
    out %>%
        dplyr::group_by(CHROM) %>%
        dplyr::arrange(POS, .by_group = TRUE) %>%
        dplyr::mutate(Gprime = smooth_stat_locfit(POS, G, window_size = WINDOW_SIZE)) %>%
        dplyr::ungroup() %>%
        dplyr::filter(!is.na(Gprime), is.finite(Gprime))
}

