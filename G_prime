        title_text = paste0("Residual G' after masking pfcrt and pfaat1 - Competition Day ", this_day),
        outfile = paste0("Gprime_residual_competition_day_", this_day, ".png"),
        value_col = "Gprime_plot",
        show_gene_lines = FALSE,
        y_lab = "Residual G'"
    )
}

# ============================================================
# 4) RESIDUAL MERGED PLOT ACROSS ALL DAYS
#   this now behaves like your other BSA overlay:
#   masked regions are absent from Chr07 and Chr06
# ============================================================
merged_resid_df <- gprime_pairwise_results %>%
    dplyr::filter(!is.na(Gprime_plot), is.finite(Gprime_plot)) %>%
    dplyr::mutate(
        CHROM = factor(as.character(CHROM), levels = chr_levels),
        DrugConc = factor(as.character(DrugConc), levels = c("50 nM", "100 nM", "250 nM"))
    ) %>%
    droplevels()

merged_resid_thr <- threshold_tbl_resid %>%
    dplyr::group_by(DrugConc) %>%
    dplyr::summarise(
        thr_p10 = median(thr_p10, na.rm = TRUE),
        thr_p05 = median(thr_p05, na.rm = TRUE),
        thr_p01 = median(thr_p01, na.rm = TRUE),
        .groups = "drop"
    ) %>%
    dplyr::mutate(DrugConc = factor(as.character(DrugConc), levels = c("50 nM", "100 nM", "250 nM")))

plot_merged_overlay(
    df = merged_resid_df,
    thr_df = merged_resid_thr,
    value_col = "Gprime_plot",
    title_text = "Genome-wide residual G' overlay after masking pfcrt and pfaat1",
    outfile = "Gprime_residual_merged_overlay_all_competition_days.png",
    y_lab = "G' value"
)
